SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-here
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_SECRET_KEY=your-supabase-secret-key
FLASK_ENV=development
FLASK_APP=run.py

# Database connection (Supabase Postgres). Either set DATABASE_URL directly,
# or set the DB_* parts and it will be assembled for you.
#
# Prefer the connection pooler over the direct host: db.<ref>.supabase.co
# is IPv6-only and fails on IPv4-only environments (e.g. this app's Vercel
# deployment). Use aws-<cluster>-<region>.pooler.supabase.com instead, with
# DB_USER in the form postgres.<project-ref>.
DATABASE_URL=
DB_USER=postgres.your-project-ref
DB_PASSWORD=your-db-password-here
DB_HOST=aws-<cluster>-<region>.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres